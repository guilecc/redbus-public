{
  "name": "redbus",
  "version": "1.0.4",
  "description": "RedBus - Assistente de Trabalho Autônomo Local",
  "author": {
    "name": "Guile Cardoso",
    "email": "guile@redbus.app"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "electron-builder install-app-deps && vite",
    "clean": "rm -rf release dist dist-electron",
    "build": "npm run clean && tsc && vite build && electron-builder",
    "build:mac": "npm run clean && tsc && vite build && electron-builder --mac",
    "build:win": "npm run clean && tsc && vite build && electron-builder --win",
    "build:linux": "npm run clean && tsc && vite build && electron-builder --linux",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:electron": "electron-builder install-app-deps",
    "rebuild:node": "npm rebuild better-sqlite3",
    "test": "npm run rebuild:node && (vitest run; EXIT_CODE=$?; npm run rebuild:electron; exit $EXIT_CODE)"
  },
  "build": {
    "appId": "com.redbus.app",
    "productName": "RedBus",
    "directories": {
      "output": "release",
      "buildResources": "icons"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**",
      "node_modules/prebuild-install/**"
    ],
    "extraResources": [
      {
        "from": "icons/icon.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icons/macos/icon.icns",
      "category": "public.app-category.productivity",
      "gatekeeperAssess": false,
      "hardenedRuntime": true
    },
    "win": {
      "executableName": "RedBus",
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icons/windows/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "RedBus",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icons/linux/icons",
      "category": "Utility"
    }
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.5.0",
    "cron-parser": "^5.5.0",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "node-cron": "^4.2.1",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.2",
    "tesseract.js": "^7.0.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.8.4",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.7",
    "jsdom": "^28.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18"
  }
}
